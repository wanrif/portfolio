{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite --host",
    "build": "tsc -b && vite build",
    "lint": "bunx oxlint ./src --tsconfig ./tsconfig.app.json --type-aware -D suspicious --deny-warnings",
    "lint:fix": "bunx oxlint ./src --tsconfig ./tsconfig.app.json --type-aware -D suspicious --fix --fix-suggestions --deny-warnings",
    "format": "bun run lint:fix",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@reduxjs/toolkit": "^2.5.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.2.2",
    "clsx": "2.1.1",
    "framer-motion": "^12.34.3",
    "gsap": "^3.12.7",
    "lodash": "^4.17.21",
    "lz-string": "^1.5.0",
    "moment": "^2.30.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.4.0",
    "react-particles": "^2.12.2",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "tailwind-merge": "3.5.0",
    "tsparticles-slim": "^2.12.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/moment": "^2.11.29",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.20",
    "oxlint": "^1.24.0",
    "oxlint-tsgolint": "^0.15.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^4.2.1",
    "terser": "^5.38.2",
    "typescript": "^5.7.3",
    "vite": "^7.3.1"
  }
}
