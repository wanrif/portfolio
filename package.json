{
  "name": "portfolio",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite --host",
    "build": "tsc -b && vite build",
    "lint": "bunx oxlint ./src --tsconfig ./tsconfig.app.json --type-aware -D suspicious --deny-warnings",
    "lint:fix": "bunx oxlint ./src --tsconfig ./tsconfig.app.json --type-aware -D suspicious --fix --fix-suggestions --deny-warnings",
    "format": "bun run lint:fix",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "^4.2.1",
    "@toolwind/corner-shape": "^0.0.8-3",
    "@types/bun": "^1.2.2",
    "clsx": "2.1.1",
    "framer-motion": "^12.34.3",
    "gsap": "^3.12.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.4.0",
    "react-particles": "^2.12.2",
    "tailwind-merge": "3.5.0",
    "tsparticles-slim": "^2.12.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.20",
    "oxlint": "^1.24.0",
    "oxlint-tsgolint": "^0.15.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^4.2.1",
    "terser": "^5.38.2",
    "typescript": "^5.7.3",
    "vite": "^7.3.1"
  }
}
